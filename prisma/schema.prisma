// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth / Ownership ────────────────────────────────────────────────────────

model User {
  id        String   @id // Clerk user ID
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  trees     Tree[]
  stories   Story[]
  photos    Photo[]
}

// ─── Core Domain ─────────────────────────────────────────────────────────────

model Tree {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  persons   Person[]
  stories   Story[]
  photos    Photo[]
}

model Person {
  id              String    @id @default(cuid())
  treeId          String
  tree            Tree      @relation(fields: [treeId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  birthDate       DateTime?
  deathDate       DateTime?
  birthPlace      String?
  gender          Gender    @default(UNKNOWN)
  bio             String?
  profilePhotoUrl String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // soft delete

  relationshipsAsA Relationship[] @relation("PersonA")
  relationshipsAsB Relationship[] @relation("PersonB")

  storyPersons    StoryPerson[]
  photoPersons    PhotoPerson[]
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

model Relationship {
  id        String           @id @default(cuid())
  personA   Person           @relation("PersonA", fields: [personAId], references: [id])
  personAId String
  personB   Person           @relation("PersonB", fields: [personBId], references: [id])
  personBId String
  type      RelationshipType

  @@unique([personAId, personBId, type])
}

enum RelationshipType {
  PARENT_OF // personA is parent of personB
  SPOUSE_OF // personA is spouse of personB
}

// ─── Content ──────────────────────────────────────────────────────────────────

model Story {
  id        String   @id @default(cuid())
  treeId    String
  tree      Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  title     String
  content   String   @db.Text
  audioUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storyPersons StoryPerson[]
}

model StoryPerson {
  storyId  String
  personId String
  story    Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([storyId, personId])
}

model Photo {
  id           String   @id @default(cuid())
  treeId       String
  tree         Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  url          String
  caption      String?
  takenAt      DateTime?

  createdAt    DateTime @default(now())

  photoPersons PhotoPerson[]
}

model PhotoPerson {
  photoId  String
  personId String
  photo    Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([photoId, personId])
}
